            <td>Curador CEPI</td>
            <td><code>curador.cepi@lab-ia.gov.br</code></td>
            <td><code>123456789</code></td>
          </tr>
          <tr>
            <td><strong>Operador Publico</strong></td>
            <td>Operador CEPI</td>
            <td><code>operador.cepi@lab-ia.gov.br</code></td>
            <td><code>123456789</code></td>
          </tr>
          <tr>
